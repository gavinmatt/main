---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  sideBarActiveItemID="flight-tracker"
  customTitle="Flight Tracker"
  description="Live ADS-B aircraft tracking from a personal antenna in northwest Montana. View current overhead flights and the furthest-away aircraft ever received."
  canonical="https://www.gavmatt.com/flight-tracker"
  ogImage="https://www.gavmatt.com/flight-tracker.png"
>
  <!-- HEADER -->
  <div class="text-5xl font-bold text-center mt-6">
    Live air traffic near Whitefish, MT
  </div>

  <p class="text-center py-4 max-w-3xl mx-auto">
    All data is captured from my home ADS-B antenna setup and reflects only
    aircraft my local receiver can hear (not aggregated radar data).
    <a href="/blog/flight-tracking" class="underline">Learn more</a>.
  </p>

  <!-- RADAR -->
  <div class="flex justify-center">
    <iframe
      src="https://globe.adsbexchange.com/?feed=dzxvAzrTfUSY&hideSidebar&hideButtons&hideStats&zoom=7&lat=48.415&lon=-114.459&rings"
      width="800"
      height="600"
      frameborder="0"></iframe>
  </div>

  <!-- TAB NAVIGATION -->
  <div class="mt-12" style="width: 100%; max-width: 1280px; margin-left: auto; margin-right: auto; padding-left: 1rem; padding-right: 1rem;">
    <div class="flex border-b border-gray-300 gap-1 w-full">
      <button
        id="tab-overhead"
        class="tab-btn px-5 py-2.5 text-base font-bold border-b-2 border-black text-black -mb-px"
        onclick="switchTab('overhead')"
      >
        What's overhead?
      </button>
      <button
        id="tab-distant"
        class="tab-btn px-5 py-2.5 text-base font-bold border-b-2 border-transparent text-gray-500 -mb-px hover:text-gray-800"
        onclick="switchTab('distant')"
      >
        Distant pings
      </button>
      <button
        id="tab-frequent"
        class="tab-btn px-5 py-2.5 text-base font-bold border-b-2 border-transparent text-gray-500 -mb-px hover:text-gray-800"
        onclick="switchTab('frequent')"
      >
        Frequent fliers
      </button>
      <button
        id="tab-heatmap"
        class="tab-btn px-5 py-2.5 text-base font-bold border-b-2 border-transparent text-gray-500 -mb-px hover:text-gray-800"
        onclick="switchTab('heatmap')"
      >
        Traffic heatmap
      </button>
    </div>

    <!-- TAB: OVERHEAD -->
    <div id="panel-overhead" class="tab-panel pt-6 w-full" style="width:100%">
      <p class="text-gray-900 mb-3 text-base">
        Data about the planes currently flying in reach of my antenna. "—" and
        missing values are expected - not all planes send data and
        data is lost at range. The table will also flag interesting or uncommon
        flights.
      </p>
      <p id="lastUpdated" class="text-base text-gray-500 mb-4"></p>

      <div
        id="emptyState"
        class="hidden mt-4 mb-4 text-center border border-dashed rounded-lg py-10 px-6 text-gray-500"
      >
        <div class="text-xl font-semibold mb-2">No aircraft currently in range</div>
        <p class="text-sm">
          My receiver is online and listening, but there are no aircraft
          transmitting decodable ADS-B data within range right now.
        </p>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-base text-gray-900">
          <thead>
            <tr class="border-b text-gray-700">
              <th class="text-left py-2 px-2">Interesting?</th>
              <th class="text-left py-2 px-2">Airline</th>
              <th class="text-left py-2 px-2">Callsign</th>
              <th class="text-left py-2 px-2">Type</th>
              <th class="text-left py-2 px-2">ICAO</th>
              <th class="text-right py-2 px-2">Altitude (ft)</th>
              <th class="text-right py-2 px-2">Speed (kt)</th>
              <th class="text-right py-2 px-2">Track</th>
              <th class="text-right py-2 px-2">Distance (NM)</th>
              <th class="text-right py-2 px-2">Last Seen (s)</th>
            </tr>
          </thead>
          <tbody id="flightBody" class="text-gray-900"></tbody>
        </table>
      </div>
    </div>

    <!-- TAB: DISTANT PINGS -->
    <div id="panel-distant" class="tab-panel pt-6 hidden w-full" style="width:100%">
      <p class="text-gray-900 mb-1 text-base">
        Furthest away aircraft I've tracked. 1 NM = ~1.15 miles.
      </p>
      <p class="text-gray-900 mb-4 text-base">
        Good = 120–180 NM, great = 180–250 NM, amazing = 250+ NM for my setup.
      </p>

      <div class="overflow-x-auto">
        <table class="min-w-full border-collapse text-base text-gray-900">
          <thead>
            <tr class="border-b text-gray-700">
              <th class="text-center py-2 px-3">Ranking</th>
              <th class="text-center py-2 px-3">Distance Rating</th>
              <th class="text-left py-2 px-3">Airline</th>
              <th class="text-left py-2 px-3">Callsign</th>
              <th class="text-right py-2 px-3">Max Distance (NM)</th>
              <th class="text-right py-2 px-3">Last Seen</th>
            </tr>
          </thead>
          <tbody id="notableBody"></tbody>
        </table>
      </div>
    </div>

    <!-- TAB: FREQUENT FLIERS -->
    <div id="panel-frequent" class="tab-panel pt-6 hidden w-full" style="width:100%">
      <p class="text-gray-900 mb-4 text-base">
        Callsigns I've seen pass through most often. Route callsigns repeat daily,
        so this is effectively a ranking of the busiest routes over my antenna.
      </p>

      <div class="overflow-x-auto">
        <table class="min-w-full border-collapse text-base text-gray-900">
          <thead>
            <tr class="border-b text-gray-700">
              <th class="text-center py-2 px-3">Ranking</th>
              <th class="text-left py-2 px-3">Airline</th>
              <th class="text-left py-2 px-3">Callsign</th>
              <th class="text-right py-2 px-3">Times Seen</th>
              <th class="text-right py-2 px-3">Last Seen</th>
            </tr>
          </thead>
          <tbody id="frequentFliersBody"></tbody>
        </table>
      </div>
    </div>

    <!-- TAB: HEATMAP -->
    <div id="panel-heatmap" class="tab-panel pt-6 hidden w-full" style="width:100%">
      <p class="text-gray-900 mb-1 text-base">
        Unique flights overhead by hour and day of week (Mountain Time, rolling 90 days).
      </p>
      <p class="text-gray-500 mb-6 text-sm">Darker = more traffic. Each cell counts distinct ICAO codes — a flight seen multiple times in the same hour only counts once.</p>

      <div id="heatmapContainer" class="overflow-x-auto">
        <div id="heatmapGrid"></div>
      </div>
    </div>
  </div>

  <!-- SCRIPT -->
  <script type="module">
    /* ---------- TAB SWITCHING ---------- */

    window.switchTab = function(name) {
      document.querySelectorAll('.tab-panel').forEach(p => {
        p.style.height = '0';
        p.style.overflow = 'hidden';
        p.style.paddingTop = '0';
      });
      document.querySelectorAll('.tab-btn').forEach(b => {
        b.classList.remove('border-black', 'text-black');
        b.classList.add('border-transparent', 'text-gray-500');
      });
      const panel = document.getElementById('panel-' + name);
      panel.style.height = 'auto';
      panel.style.overflow = 'visible';
      panel.style.paddingTop = '1.5rem';
      const btn = document.getElementById('tab-' + name);
      btn.classList.remove('border-transparent', 'text-gray-500');
      btn.classList.add('border-black', 'text-black');
    };

    // Init: collapse non-overhead panels
    ['panel-distant', 'panel-frequent', 'panel-heatmap'].forEach(id => {
      const p = document.getElementById(id);
      p.classList.remove('hidden');
      p.style.height = '0';
      p.style.overflow = 'hidden';
      p.style.paddingTop = '0';
    });

    /* ---------- CONSTANTS ---------- */

    const tbody = document.getElementById("flightBody");
    const emptyStateEl = document.getElementById("emptyState");
    const lastUpdatedEl = document.getElementById("lastUpdated");
    const STALE_AFTER_MS = 90_000;

    const RX_LAT = 48.415;
    const RX_LON = -114.459;

    /* ---------- UTILS ---------- */

    function distanceNm(lat1, lon1, lat2, lon2) {
      const R = 3440.065;
      const toRad = (d) => (d * Math.PI) / 180;
      const dLat = toRad(lat2 - lat1);
      const dLon = toRad(lon2 - lon1);
      const a =
        Math.sin(dLat / 2) ** 2 +
        Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) * Math.sin(dLon / 2) ** 2;
      return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
    }

    function aircraftDistance(f) {
      if (f.lat == null || f.lon == null) return null;
      return distanceNm(RX_LAT, RX_LON, f.lat, f.lon);
    }

    function distanceFlag(d) {
      if (d > 250) return { label: "EXTREME", cls: "bg-purple-100 text-purple-800" };
      if (d > 200) return { label: "LONG-RANGE", cls: "bg-indigo-100 text-indigo-800" };
      if (d > 150) return { label: "DISTANT", cls: "bg-blue-100 text-blue-800" };
      return null;
    }

    function notableLabelForFlight(f) {
      if (hexUpper(f).startsWith("AE")) return "USAF";
      const cs = callsignRaw(f);
      if (/^(ENRGY|QID|TEX|GOLD|NACHO|RCH|REACH|MC|AMC)/.test(cs)) return "USAF";
      return airlineFromFlight(f);
    }

    function notableDistanceLabel(d) {
      if (d >= 250) return { label: "AMAZING", cls: "bg-purple-100 text-purple-800" };
      if (d >= 180) return { label: "GREAT", cls: "bg-indigo-100 text-indigo-800" };
      if (d >= 120) return { label: "GOOD", cls: "bg-blue-100 text-blue-800" };
      return null;
    }

    /* ---------- NOTABLES ---------- */

    function renderNotables(rows) {
      const notableBody = document.getElementById("notableBody");
      if (!notableBody) return;
      if (!rows || !rows.length) {
        notableBody.innerHTML = `<tr><td colspan="6" class="text-center py-6 text-gray-500">No notable pings recorded yet.</td></tr>`;
        return;
      }
      const medals = ["🥇", "🥈", "🥉"];
      notableBody.innerHTML = rows.map((r, i) => {
        const fakeFlight = { flight: r.callsign };
        const rank = medals[i] ?? "";
        const label = notableDistanceLabel(r.maxDistance);
        return `
          <tr class="border-b">
            <td class="text-center py-2 px-3 text-xl">${rank}</td>
            <td class="text-center py-2 px-3">
              ${label ? `<span class="px-2 py-0.5 rounded text-xs font-medium ${label.cls}">${label.label}</span>` : "—"}
            </td>
            <td class="py-2 px-3">${r.airline && r.airline !== "—" ? r.airline : notableLabelForFlight(fakeFlight)}</td>
            <td class="py-2 px-3">${r.callsign}</td>
            <td class="text-right py-2 px-3 font-semibold">${r.maxDistance}</td>
            <td class="text-right py-2 px-3">${new Date(r.lastSeen).toLocaleDateString()}</td>
          </tr>`;
      }).join("");
    }

    async function loadNotables() {
      try {
        const res = await fetch("/api/notable-pings");
        const data = await res.json();
        renderNotables(data.rows ?? []);
      } catch {}
    }

    /* ---------- FREQUENT FLIERS ---------- */

    function renderFrequentFliers(rows) {
      const ffBody = document.getElementById("frequentFliersBody");
      if (!ffBody) return;
      if (!rows || !rows.length) {
        ffBody.innerHTML = `<tr><td colspan="5" class="text-center py-6 text-gray-500">No frequent fliers recorded yet.</td></tr>`;
        return;
      }
      const medals = ["🥇", "🥈", "🥉"];
      ffBody.innerHTML = rows.map((r, i) => {
        const rank = medals[i] ?? "";
        return `
          <tr class="border-b">
            <td class="text-center py-2 px-3 text-xl">${rank}</td>
            <td class="py-2 px-3">${airlineFromCallsign(r.callsign)}</td>
            <td class="py-2 px-3 font-mono">${r.callsign}</td>
            <td class="text-right py-2 px-3 font-semibold">${r.count}</td>
            <td class="text-right py-2 px-3">${new Date(r.lastSeen).toLocaleDateString()}</td>
          </tr>`;
      }).join("");
    }

    async function loadFrequentFliers() {
      try {
        const res = await fetch("/api/frequent-fliers");
        const data = await res.json();
        renderFrequentFliers(data.rows ?? []);
      } catch {}
    }

    /* ---------- AIRLINE LOOKUP ---------- */

    const AIRLINE_NAMES = {
      AAL: "American Airlines", DAL: "Delta Air Lines", UAL: "United Airlines",
      ASA: "Alaska Airlines", SWA: "Southwest Airlines", JBU: "JetBlue Airways",
      NKS: "Spirit Airlines", FFT: "Frontier Airlines", SKW: "SkyWest Airlines",
      ACA: "Air Canada", ROU: "Air Canada Rouge", WJA: "WestJet", WEN: "WestJet Encore",
      TSC: "Air Transat", SWG: "Sunwing", FLE: "Flair Airlines", QXE: "Horizon Air",
      JZA: "Jazz", CNK: "Sunwest Aviation", LXJ: "Flexjet", VIR: "Virgin Atlantic",
      UPS: "UPS Airlines", FDX: "FedEx Express", GTI: "Atlas Air", CKS: "Kalitta Air",
      ABX: "ABX Air", POE: "Polar Air Cargo", CLX: "Cargolux", MNB: "ASL Airlines Belgium",
      EGG: "Western Global Airlines", MAL: "Morningstar Air", CJT: "Cargojet",
      ATN: "Air Transport International", CFS: "Empire Airlines", AAY: "Allegiant",
      SCX: "Sun Country Airlines", BAW: "British Airways", DLH: "Lufthansa",
      KLM: "KLM Royal Dutch Airlines", AFR: "Air France", SAS: "Scandinavian Airlines",
      FIN: "Finnair", IBE: "Iberia", TAP: "TAP Air Portugal", LOT: "LOT Polish Airlines",
      AUA: "Austrian Airlines", SWR: "SWISS", EIN: "Aer Lingus", CFG: "Condor",
      ICE: "Icelandair", FBU: "French Bee", ANA: "All Nippon Airways", JAL: "Japan Airlines",
      KAL: "Korean Air", CPA: "Cathay Pacific", EVA: "EVA Air", CAL: "China Airlines",
      AIC: "Air India", UAE: "Emirates", QQE: "Qatar Executive", QTR: "Qatar Airways",
      ETD: "Etihad Airways", SVA: "Saudia", THY: "Turkish Airlines", IFA: "Fai Airservice",
      HRT: "Chartright Air", ETH: "Ethiopian Airlines", RAM: "Royal Air Maroc",
      JAS: "Janus Airways", AEL: "AirExplore", BCS: "DHL Air", EWG: "Eurowings",
      TUI: "TUI Airways", CAP: "Civil Air Patrol", ASP: "AirSprint", AIP: "Alpine Aviation",
      EJA: "NetJets", AMF: "Ameriflight", VJA: "VistaAmerica", AJI: "Ameristar Jet Charter",
      TWY: "Sunset Aviation", SPA: "Sierra Pacific", KOW: "Baker Aviation",
      RAX: "Royal Air Freight", CBC: "SkyShare", RDN: "Red Barn Operations", TFF: "Talon Air",
      EJM: "Executive Jet Management", SYB: "SkyService Business Aviation", AZG: "Ameriflight",
      TKJ: "AJet", SDE: "Air Partners", CYO: "ATI Jet", NJM: "Northern Jet Management",
      LKF: "Aviation Advisor", ICV: "Cargolux Italia", JCM: "Secure Air Charter", DLX: "Dreamline Aviation", FGD: "Conair Aviation", ADS: "Anderson Air",
    };

    const COMMON_AIRLINES = new Set([
      "American Airlines", "Delta Air Lines", "United Airlines", "Alaska Airlines",
      "Southwest Airlines", "JetBlue Airways", "Spirit Airlines", "Frontier Airlines",
      "Air Canada", "Air Canada Rouge", "WestJet", "WestJet Encore", "FedEx Express",
      "UPS Airlines", "Flair Airlines", "Horizon Air", "Cargojet",
      "Air Transport International", "SkyWest Airlines", "Sunwest Aviation",
      "Empire Airlines", "Alpine Aviation", "NetJets", "Ameriflight", "VistaAmerica",
      "Allegiant", "Ameristar Jet Charter", "Chartright Air", "Sunset Aviation",
      "Sierra Pacific", "Baker Aviation", "Sun Country Airlines",
    ]);

    function airlineFromCallsign(cs) {
      if (!cs) return "—";
      if (/^N\d{1,5}[A-Z]{0,2}$/.test(cs)) return "Private";
      if (/^C-?[FG][A-Z]{3}$/.test(cs)) return "Private";
      if (/^G-?[A-Z]{4}$/.test(cs)) return "Private";
      if (/^D-?[A-Z]{4}$/.test(cs)) return "Private";
      if (/^HB-?[A-Z]{3}$/.test(cs)) return "Private";
      if (/^NCJ\d+/.test(cs)) return "Private";
      const prefix = cs.match(/^[A-Z]{2,3}/)?.[0];
      return AIRLINE_NAMES[prefix] || "—";
    }

    function callsignRaw(f) {
      const cs = (f.flight || f.callsign || "").trim().toUpperCase();
      if (!cs || cs === "00000000") return "";
      return cs;
    }

    function isUnknownAirline(f) {
      const cs = callsignRaw(f);
      if (!cs) return false;
      const looksLikeAirline = /^[A-Z]{2,3}\d/.test(cs);
      if (!looksLikeAirline) return false;
      const prefix = cs.match(/^[A-Z]{2,3}/)?.[0];
      return !AIRLINE_NAMES[prefix];
    }

    function isPrivateFlight(f) {
      const cs = callsignRaw(f);
      if (!cs) return false;
      if (/^NCJ\d+/.test(cs)) return "Private";
      return (
        /^N\d{1,5}[A-Z]{0,2}$/.test(cs) ||
        /^C-?[FG][A-Z]{3}$/.test(cs) ||
        /^G-?[A-Z]{4}$/.test(cs) ||
        /^D-?[A-Z]{4}$/.test(cs) ||
        /^HB-?[A-Z]{3}$/.test(cs)
      );
    }

    function isAirlineFlight(f) {
      const cs = callsignRaw(f);
      return /^[A-Z]{2,3}\d/.test(cs);
    }

    function hexUpper(f) {
      return f.hex?.toUpperCase() ?? "";
    }

    function airlineFromFlight(f) {
      const cs = callsignRaw(f);
      if (/^BOE\d+/.test(cs)) return "Boeing Test Flight";
      if (/^RDN\d+/.test(cs)) return "Special Operations";
      if (isPrivateFlight(f)) return "Private";
      if (f.op?.trim()) return f.op.trim();
      if (!cs) return "Undetermined";
      const prefix = cs.match(/^[A-Z]{2,3}/)?.[0];
      return AIRLINE_NAMES[prefix] || "—";
    }

    function militaryBranch(f) {
      const cs = callsignRaw(f);
      if (hexUpper(f).startsWith("AE")) {
        if (/^(ENRGY|QID|TEX|GOLD|NACHO)/.test(cs) || ((f.alt_baro ?? 0) > 30000 && (f.gs ?? 0) < 500)) {
          return "USAF (TANKER)";
        }
        return "USAF";
      }
      if (/^(ENRGY|QID|TEX|GOLD|NACHO|RCH|REACH|MC|AMC)/.test(cs)) return "USAF (TANKER)";
      if (/^(NAVY|CNV|VV)/.test(cs)) return "USN";
      if (/^(PAT|ARMY)/.test(cs)) return "USA";
      if (/^(VM|MAR)/.test(cs)) return "USMC";
      return null;
    }

    function classifyNotability(f) {
      const cs = callsignRaw(f);
      if (f.category === "A7") return { label: "HELI", cls: "bg-emerald-100 text-emerald-800" };
      if (/^BOE\d+/.test(cs)) return { label: "Test Flight", cls: "bg-amber-100 text-amber-800" };
      const branch = militaryBranch(f);
      if (branch) {
        return {
          label: branch,
          cls: branch.includes("TANKER") ? "bg-red-200 text-red-900" : "bg-red-100 text-red-800",
        };
      }
      const airline = airlineFromFlight(f);
      if (isAirlineFlight(f) && airline !== "—" && airline !== "Private" && !COMMON_AIRLINES.has(airline)) {
        return { label: "UNCOMMON", cls: "bg-blue-100 text-blue-800" };
      }
      if ((f.alt_baro ?? 0) > 45000 || (f.gs ?? 0) > 550) {
        return { label: "FAST/HIGH", cls: "bg-yellow-100 text-yellow-800" };
      }
      return null;
    }

    function aircraftType(f) {
      if (f.category === "A7") return "Helicopter";
      if (hexUpper(f).startsWith("AE")) return "Military";
      switch (f.category) {
        case "A5": return "Heavy Jet";
        case "A3": return "Large Jet";
        case "A2": return "Turboprop";
        case "A1": return "Light Aircraft";
      }
      return "—";
    }

    function isStale(f) {
      return typeof f.seen === "number" && f.seen > STALE_AFTER_MS / 1000;
    }

    function secondsSinceSeen(f) {
      if (typeof f.seen === "number") return Math.round(f.seen);
      return "—";
    }

    function callsignDisplay(f) {
      const cs = callsignRaw(f);
      return cs || "No callsign";
    }

    /* ---------- RENDER LIVE FLIGHTS ---------- */

    function render(flights) {
      const activeFlights = flights
        .filter((f) => !isStale(f))
        .sort((a, b) => (aircraftDistance(b) ?? 0) - (aircraftDistance(a) ?? 0));

      if (!activeFlights.length) {
        tbody.innerHTML = "";
        emptyStateEl.classList.remove("hidden");
        return;
      }

      emptyStateEl.classList.add("hidden");

      tbody.innerHTML = activeFlights.map((f) => {
        if (isUnknownAirline(f)) {
          console.log("[UNKNOWN_AIRLINE]", {
            callsign: callsignRaw(f), hex: f.hex,
            alt: f.alt_baro ?? f.alt_geom, gs: f.gs,
            distance_nm: aircraftDistance(f), seen_s: f.seen,
          });
        }
        const note = classifyNotability(f);
        const d = aircraftDistance(f);
        const dFlag = d != null ? distanceFlag(d) : null;
        return `
          <tr class="border-b text-gray-900">
            <td class="py-2 px-2 space-x-1 text-gray-400">
              ${note || dFlag ? `
                ${note ? `<span class="px-2 py-0.5 rounded text-xs font-medium ${note.cls}">${note.label}</span>` : ""}
                ${dFlag ? `<span class="px-2 py-0.5 rounded text-xs font-medium ${dFlag.cls}">${dFlag.label}</span>` : ""}
              ` : "—"}
            </td>
            <td class="py-2 px-2">${airlineFromFlight(f)}</td>
            <td class="py-2 px-2">${callsignDisplay(f)}</td>
            <td class="py-2 px-2">${aircraftType(f)}</td>
            <td class="py-2 px-2">${f.hex || "—"}</td>
            <td class="text-right py-2 px-2">${f.alt_baro ?? f.alt_geom ?? "—"}</td>
            <td class="text-right py-2 px-2">${f.gs ?? "—"}</td>
            <td class="text-right py-2 px-2">${f.track ?? "—"}</td>
            <td class="text-right py-2 px-2">${d != null ? Math.round(d) : "—"}</td>
            <td class="text-right py-2 px-2">${secondsSinceSeen(f)}</td>
          </tr>`;
      }).join("");
    }

    async function updateFlights() {
      try {
        const res = await fetch("/api/flights");
        if (res.status === 204) return;
        const data = await res.json();
        render(data.aircraft ?? []);
        lastUpdatedEl.textContent = "Last updated " + new Date(data.receivedAt).toLocaleTimeString();
      } catch {}
    }

    updateFlights();
    setInterval(updateFlights, 10000);
    loadNotables();
    loadFrequentFliers();
    loadHeatmap();
    setInterval(loadNotables, 60000);
    setInterval(loadFrequentFliers, 60000);
    setInterval(loadHeatmap, 60000);

    /* ---------- HEATMAP ---------- */

    const DAYS = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];
    const HOURS = Array.from({ length: 24 }, (_, i) =>
      i === 0 ? "12a" : i < 12 ? `${i}a` : i === 12 ? "12p" : `${i - 12}p`
    );

    function heatmapColor(value, max) {
      if (max === 0 || value === 0) return "#f3f4f6";
      const intensity = value / max;
      const r = Math.round(239 - intensity * 210);
      const g = Math.round(246 - intensity * 200);
      const b = Math.round(255 - intensity * 100);
      return `rgb(${r},${g},${b})`;
    }

    function renderHeatmap(grid) {
      const container = document.getElementById("heatmapGrid");
      if (!container) return;

      const max = Math.max(...grid.flatMap(row => row));

      const cellSize = "36px";

      let html = `<table style="border-collapse:separate; border-spacing:3px; font-size:12px;">`;

      html += `<thead><tr><th style="width:36px"></th>`;
      for (const h of HOURS) {
        html += `<th style="width:${cellSize}; text-align:center; color:#6b7280; font-weight:500; padding-bottom:4px;">${h}</th>`;
      }
      html += `</tr></thead><tbody>`;

      for (let d = 0; d < 7; d++) {
        html += `<tr>`;
        html += `<td style="text-align:right; padding-right:8px; color:#6b7280; font-weight:500; white-space:nowrap;">${DAYS[d]}</td>`;
        for (let h = 0; h < 24; h++) {
          const val = grid[d][h];
          const bg = heatmapColor(val, max);
          const textColor = val / max > 0.5 ? "#fff" : "#374151";
          const title = `${DAYS[d]} ${HOURS[h]}: ${val} flight${val !== 1 ? "s" : ""}`;
          html += `<td title="${title}" style="width:${cellSize}; height:${cellSize}; background:${bg}; border-radius:3px; text-align:center; vertical-align:middle; color:${textColor}; cursor:default;">`;
          if (val > 0) html += `<span style="font-size:10px;">${val}</span>`;
          html += `</td>`;
        }
        html += `</tr>`;
      }

      html += `</tbody></table>`;

      html += `<div style="margin-top:12px; display:flex; align-items:center; gap:6px; font-size:12px; color:#6b7280;">`;
      html += `<span>Less</span>`;
      for (let i = 0; i <= 8; i++) {
        const bg = heatmapColor(i, 8);
        html += `<div style="width:18px; height:18px; background:${bg}; border-radius:2px; border:1px solid #e5e7eb;"></div>`;
      }
      html += `<span>More</span></div>`;

      container.innerHTML = html;
    }

    async function loadHeatmap() {
      try {
        const res = await fetch("/api/heatmap");
        const data = await res.json();
        renderHeatmap(data.grid);
      } catch {}
    }
  </script>
</BaseLayout>