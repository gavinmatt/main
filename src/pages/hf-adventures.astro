---
import BaseLayout from '../layouts/BaseLayout.astro';
import QSLMap from '../components/QSLMap.tsx';
---

<BaseLayout title="Amateur Radio" sideBarActiveItemID="radio">
  <div class="pb-12 mt-5">
    <div class="text-3xl py-3 font-bold">Amateur Radio</div>
    <div class="py-2 text-lg">
      I have my amateur radio license and regularly operate on UHF, VHF, and HF bands. I use a EFHW antenna in my attic with a Kenwood TS-590S and hope and pray for good conditions to crack through the noise. 
      </div>
    <div class="py-2 text-lg">
      This widget shows a map of confirmed DX (long distance) contacts (called QSLs) on various HF radio bands, my longest distance contacts, and even notable/rare/hard contacts.
    </div>
    <div class="divider my-0" />
    <div class="mt-6">
      <QSLMap client:only="react" />
    </div>
  </div>
</BaseLayout>